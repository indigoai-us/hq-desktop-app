{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the HQ Installer webview.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:path:default",
    "core:event:default",
    "core:app:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.execute-api.us-east-1.amazonaws.com/*" },
        { "url": "https://hqapi.getindigo.ai/*" },
        { "url": "https://hqapi.hq.computer/*" },
        { "url": "https://*.auth.us-east-1.amazoncognito.com/*" },
        { "url": "https://cognito-idp.us-east-1.amazonaws.com/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://codeload.github.com/*" },
        { "url": "https://*.s3.amazonaws.com/*" },
        { "url": "https://*.s3.us-east-1.amazonaws.com/*" },
        { "url": "https://s3.us-east-1.amazonaws.com/*" },
        { "url": "https://telemetry.getindigo.ai/*" },
        { "url": "https://telemetry.hq.computer/*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" },
        { "path": "$HOME/.hq" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" },
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" },
        { "path": "$HOME/.hq/embeddings-pending.json" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" },
        { "path": "$HOME/.hq" },
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$RESOURCE/templates/**" },
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/hq" },
        { "path": "$HOME/hq/**" },
        { "path": "$HOME/hq/.*" },
        { "path": "$HOME/hq/.*/**" },
        { "path": "$HOME/hq/**/.*" },
        { "path": "$HOME/hq/**/.*/**" },
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    }
  ]
}
