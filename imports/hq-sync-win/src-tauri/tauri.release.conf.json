  "build": {
    "beforeBuildCommand": "npm run build && node sidecar/recall-sdk-bridge/build.mjs"
  },
  "bundle": {
    "resources": {
      "../sidecar/recall-sdk-bridge/bridge.mjs": "recall-sdk-bridge/bridge.mjs",
