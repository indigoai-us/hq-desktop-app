{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "HQ Sync",
  "version": "0.6.3",
  "identifier": "ai.indigo.hq-sync-win",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HQ Sync",
        "width": 352,
        "height": 528,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklFVkNPRFk0T0RReVJUTkJSRUZFTmpVS1VsZFNiSEpoTTJwUmIybEhOalZTUTNOb1NXRmxNVVV5TTJadWREYzVSbXBZUldjMlIxVkpXV0kyYlRCblQyaDNSMjh4WkVOeVV6a0s=",
      "endpoints": [
        "https://github.com/indigoai-us/hq-sync-win/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Indigo AI",
    "category": "Productivity",
    "shortDescription": "HQ system-tray sync agent for Windows",
    "longDescription": "Windows 11 system-tray sync agent for HQ. Syncs your HQ folder to S3 in the background, surfaces conflict resolution in a popover, and runs from the notification area with no terminal.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "digestAlgorithm": "sha256",
      "wix": {
        "language": "en-US",
        "upgradeCode": "8E5B6C7F-3A2D-4B1E-9F0C-1D2E3F4A5B6C",
        "componentGroupRefs": [],
        "componentRefs": [],
        "featureGroupRefs": [],
        "featureRefs": [],
        "mergeRefs": []
      },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
