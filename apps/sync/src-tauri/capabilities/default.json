{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the HQ Sync menubar webview.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:path:default",
    "core:event:default",
    "core:app:default",
    "global-shortcut:default",
    "notification:default",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.auth.us-east-1.amazoncognito.com/*" },
        { "url": "https://cognito-idp.us-east-1.amazonaws.com/*" },
        { "url": "https://*.execute-api.us-east-1.amazonaws.com/*" },
        { "url": "https://hqapi.getindigo.ai/*" },
        { "url": "https://hqapi.hq.computer/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://codeload.github.com/*" },
        { "url": "https://*.amazonaws.com/*" },
        { "url": "https://*.s3.amazonaws.com/*" },
        { "url": "https://*.s3.us-east-1.amazonaws.com/*" },
        { "url": "https://s3.us-east-1.amazonaws.com/*" },
        { "url": "https://telemetry.getindigo.ai/*" },
        { "url": "https://telemetry.hq.computer/*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/.hq" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.hq/**" },
        { "path": "$HOME/HQ/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.hq/**" },
        { "path": "$HOME/HQ/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/.hq/**" },
        { "path": "$HOME/HQ/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/.hq/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.hq/cognito-tokens.json" },
        { "path": "$HOME/.hq/.cognito-tokens.json.tmp.*" }
      ]
    }
  ]
}
