{
  "name": "hq-sync",
  "private": true,
  "version": "0.8.34",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:preview": "vite --config vite.preview.config.ts",
    "build": "vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-check --tsconfig ./tsconfig.json --threshold error",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "sidecar:install": "pnpm -C sidecar/recall-sdk-bridge install --ignore-workspace --config.minimumReleaseAge=1440",
    "bundle:debug": "npm run sidecar:install && tauri build --debug; bash scripts/fix-recall-framework-symlinks.sh \"src-tauri/target/debug/bundle/macos/HQ.app\" && bash scripts/sign-bundle.sh \"src-tauri/target/debug/bundle/macos/HQ.app\"",
    "bundle:release": "npm run sidecar:install && tauri build; bash scripts/fix-recall-framework-symlinks.sh \"src-tauri/target/release/bundle/macos/HQ.app\" && bash scripts/sign-bundle.sh \"src-tauri/target/release/bundle/macos/HQ.app\"",
    "test:e2e:desktop-alt": "vitest run --config e2e/desktop-alt/vitest.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@sentry/svelte": "^10.49.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "happy-dom": "^20.10.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.8",
    "typescript": "^5.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
