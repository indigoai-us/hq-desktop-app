{
  "name": "hq-sync",
  "private": true,
  "version": "0.1.84",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "sidecar:install": "pnpm -C sidecar/recall-sdk-bridge install --config.minimumReleaseAge=1440",
    "bundle:debug": "npm run sidecar:install && tauri build --debug; bash scripts/fix-recall-framework-symlinks.sh \"src-tauri/target/debug/bundle/macos/HQ Sync.app\"",
    "bundle:release": "npm run sidecar:install && tauri build; bash scripts/fix-recall-framework-symlinks.sh \"src-tauri/target/release/bundle/macos/HQ Sync.app\""
  },
  "dependencies": {
    "@sentry/svelte": "^10.49.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
