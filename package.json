{
  "name": "hq-desktop-app",
  "version": "0.13.0",
  "private": true,
  "description": "HQ desktop apps monorepo — installer (React) and sync (Svelte), sharing Rust crates, signing, updater, and release tooling.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:scripts": "vitest run scripts/*.test.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "version:app": "tsx scripts/version-app.ts",
    "version:check": "tsx scripts/version-app.ts --check"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "vitest": "^4.1.5"
  }
}
